# Backend Environment Variables
# Copy to .env and fill in values

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/medibuddy

# JWT
JWT_SECRET=replace_this_with_a_secure_secret_key
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Redis (for Bull job queues)
REDIS_URL=redis://localhost:6379

# SMS Provider (twilio or africastalking)
SMS_PROVIDER=twilio
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=

# Web Push (VAPID keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@medibuddy.com
PUSH_PROVIDER=webpush

# S3 for PDF storage
STORAGE_PROVIDER=backblaze
B2_BUCKET=medibuddy-pdfs
B2_REGION=us-east-005
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_KEY_ID=your_key_id_here
B2_APP_KEY=your_secret_here


# Telemetry (optional)
TELEMETRY_ENABLED=false
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# OTP Settings
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_RATE_LIMIT_REQUESTS=5
OTP_RATE_LIMIT_WINDOW_MINUTES=10
