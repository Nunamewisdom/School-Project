{
  "name": "medibuddy-backend",
  "version": "1.0.0",
  "description": "MediBuddy REST API - Medication reminders, symptom logging, and consultation summaries",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "worker": "node src/jobs/worker.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "npm test -- --coverage",
    "test:integration": "npm test -- --testPathPattern=tests/integration",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "mock": "npx @stoplight/prism-cli mock openapi.yaml -p 4010 --host 0.0.0.0",
    "gen:client": "npx @openapitools/openapi-generator-cli generate -i openapi.yaml -g typescript-axios -o ../frontend/src/api-client --additional-properties=supportsES6=true,withSeparateModelsAndApi=true",
    "lint:spec": "npx @stoplight/spectral-cli lint openapi.yaml --ruleset .spectral.yaml"
  },
  "keywords": [
    "medibuddy",
    "healthcare",
    "medication",
    "reminders",
    "pwa"
  ],
  "author": "MediBuddy Team",
  "license": "UNLICENSED",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.478.0",
    "@aws-sdk/lib-storage": "^3.980.0",
    "@aws-sdk/s3-request-presigner": "^3.980.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.14.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "web-push": "^3.6.6",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^8.55.0",
    "globals": "^17.3.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.3",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
